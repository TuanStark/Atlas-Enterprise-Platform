                {
                    "name": "Get Principal By ID",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "pm.test(\"Status code is 200\", function () {",
                                    "    pm.response.to.have.status(200);",
                                    "});",
                                    "",
                                    "pm.test(\"Validate Principal Data Schema\", function () {",
                                    "    const jsonData = pm.response.json();",
                                    "    pm.expect(jsonData.success).to.be.true;",
                                    "    pm.expect(jsonData.code).to.eql(\"PRINCIPAL_FOUND\");",
                                    "    ",
                                    "    const principal = jsonData.data;",
                                    "    pm.expect(principal.id).to.eql(pm.collectionVariables.get(\"principal_id\"));",
                                    "    pm.expect(principal.tenantId).to.eql(pm.collectionVariables.get(\"tenant_id\"));",
                                    "    pm.expect(principal.type).to.eql(\"USER\");",
                                    "    pm.expect(principal.status).to.eql(\"ACTIVE\");",
                                    "    pm.expect(principal.displayName).to.eql(\"Senior QA Automation Principal\");",
                                    "    pm.expect(principal.metadata.isAutomated).to.be.true;",
                                    "    pm.expect(principal.createdAt).to.not.be.null;",
                                    "});"
                                ],
                                "type": "javascript"
                            }
                        }
                    ],
