    "item": [
        {
            "name": "1. Setup & Happy Path Flow",
            "item": [
                {
                    "name": "Setup - Create Dynamic Tenant",
                    "event": [
                        {
                            "listen": "prerequest",
                            "script": {
                                "exec": [
                                    "const randomCode = \"TNT_\" + Math.random().toString(36).substring(2, 8).toUpperCase();",
                                    "pm.collectionVariables.set(\"dynamic_tenant_code\", randomCode);"
                                ],
                                "type": "javascript"
                            }
                        },
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "pm.test(\"Status code is 201\", function () {",
                                    "    pm.response.to.have.status(201);",
                                    "});",
                                    "",
                                    "pm.test(\"Response is success result envelope\", function () {",
                                    "    const jsonData = pm.response.json();",
                                    "    pm.expect(jsonData.success).to.be.true;",
                                    "    pm.expect(jsonData.code).to.eql(\"TENANT_CREATED\");",
                                    "});"
                                ],
                                "type": "javascript"
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"code\": \"{{dynamic_tenant_code}}\",\n    \"name\": \"QA Test Tenant (Dynamic)\",\n    \"legalName\": \"QA Tester Corp Ltd\",\n    \"taxCode\": \"TX-999234\",\n    \"email\": \"qa_tenant@example.com\",\n    \"phone\": \"+84987654321\",\n    \"timezone\": \"Asia/Ho_Chi_Minh\",\n    \"locale\": \"vi-VN\",\n    \"currency\": \"VND\"\n}",
                            "options": {
                                "raw": {
                                    "language": "json"
                                }
                            }
                        },
                        "url": {
                            "raw": "{{baseUrl}}/tenants",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "tenants"
                            ]
                        }
                    },
                    "response": []
                },
                {
                    "name": "Setup - Extract Tenant ID",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "pm.test(\"Status code is 200\", function () {",
                                    "    pm.response.to.have.status(200);",
                                    "});",
                                    "",
                                    "pm.test(\"Extract Tenant ID successfully\", function () {",
                                    "    const jsonData = pm.response.json();",
                                    "    pm.expect(jsonData.success).to.be.true;",
                                    "    pm.expect(jsonData.data).to.be.an('array');",
                                    "    ",
                                    "    const targetCode = pm.collectionVariables.get(\"dynamic_tenant_code\");",
                                    "    const matchedTenant = jsonData.data.find(t => t.code === targetCode);",
                                    "    ",
                                    "    pm.expect(matchedTenant).to.not.be.undefined;",
                                    "    pm.collectionVariables.set(\"tenant_id\", matchedTenant.id);",
                                    "    console.log(\"Saved Tenant ID:\", matchedTenant.id);",
                                    "});"
                                ],
                                "type": "javascript"
                            }
                        }
                    ],
                    "request": {
                        "method": "GET",
                        "header": [],
                        "url": {
                            "raw": "{{baseUrl}}/tenants",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "tenants"
                            ]
                        }
                    },
                    "response": []
                },
                {
                    "name": "Create Principal",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "pm.test(\"Status code is 201\", function () {",
                                    "    pm.response.to.have.status(201);",
                                    "});",
                                    "",
                                    "pm.test(\"Response conforms to Result<void> structure\", function () {",
                                    "    const jsonData = pm.response.json();",
                                    "    pm.expect(jsonData.success).to.be.true;",
                                    "    pm.expect(jsonData.statusCode).to.eql(201);",
                                    "    pm.expect(jsonData.code).to.eql(\"PRINCIPAL_CREATED\");",
                                    "    pm.expect(jsonData.message).to.contain(\"successfully\");",
                                    "});"
                                ],
                                "type": "javascript"
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"tenantId\": \"{{tenant_id}}\",\n    \"type\": \"USER\",\n    \"displayName\": \"Senior QA Automation Principal\",\n    \"metadata\": {\n        \"framework\": \"Postman\",\n        \"version\": \"v10\",\n        \"isAutomated\": true\n    }\n}",
                            "options": {
                                "raw": {
                                    "language": "json"
                                }
                            }
                        },
                        "url": {
                            "raw": "{{baseUrl}}/principals",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "principals"
                            ]
                        }
                    },
                    "response": []
                },
                {
                    "name": "List Principals & Extract ID",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "pm.test(\"Status code is 200\", function () {",
                                    "    pm.response.to.have.status(200);",
                                    "});",
                                    "",
                                    "pm.test(\"Extract Principal ID from list\", function () {",
                                    "    const jsonData = pm.response.json();",
                                    "    pm.expect(jsonData.success).to.be.true;",
                                    "    ",
                                    "    let principalArray = [];",
                                    "    if (jsonData.data && Array.isArray(jsonData.data)) {",
                                    "        principalArray = jsonData.data;",
                                    "    } else if (jsonData.data && jsonData.data.items && Array.isArray(jsonData.data.items)) {",
                                    "        principalArray = jsonData.data.items;",
                                    "    }",
                                    "    ",
                                    "    pm.expect(principalArray).to.not.be.empty;",
                                    "    const matched = principalArray.find(p => p.displayName === \"Senior QA Automation Principal\");",
                                    "    pm.expect(matched).to.not.be.undefined;",
                                    "    pm.collectionVariables.set(\"principal_id\", matched.id);",
                                    "    console.log(\"Saved Principal ID:\", matched.id);",
                                    "});"
                                ],
                                "type": "javascript"
                            }
                        }
                    ],
                    "request": {
                        "method": "GET",
                        "header": [],
                        "url": {
                            "raw": "{{baseUrl}}/principals",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "principals"
                            ]
