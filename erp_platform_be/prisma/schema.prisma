  sessionId    String            @map("session_id") @db.Uuid
  enrolledAt   DateTime?         @map("enrolled_at") @db.Timestamptz
  status       EnrollmentStatus? @map("status")
  createdAt    DateTime?         @map("created_at") @db.Timestamptz

  tenant                         Tenant                @relation(fields: [tenantId], references: [id])
  employment                     Employment            @relation(fields: [employmentId], references: [id])
  session                        TrainingSession       @relation(fields: [sessionId], references: [id])
  enrollmentTrainingResult       TrainingResult?       @relation
  enrollmentTrainingCertificates TrainingCertificate[] @relation

  @@map("training_enrollments")
}

model TrainingResult {
  id                      String    @id @default(dbgenerated("gen_random_uuid()")) @map("id") @db.Uuid
  enrollmentId            String    @unique @map("enrollment_id") @db.Uuid
  score                   Decimal?  @map("score") @db.Decimal(5, 2)
  passed                  Boolean?  @map("passed")
  feedback                String?   @map("feedback") @db.Text
  evaluatedByEmploymentId String?   @map("evaluated_by_employment_id") @db.Uuid
  evaluatedAt             DateTime? @map("evaluated_at") @db.Timestamptz

  enrollment            TrainingEnrollment @relation(fields: [enrollmentId], references: [id])
  evaluatedByEmployment Employment?        @relation(fields: [evaluatedByEmploymentId], references: [id])

  @@map("training_results")
}

model TrainingCertificate {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @map("id") @db.Uuid
  tenantId      String    @map("tenant_id") @db.Uuid
  enrollmentId  String    @map("enrollment_id") @db.Uuid
  certificateNo String?   @map("certificate_no") @db.VarChar(100)
  issuedDate    DateTime? @map("issued_date") @db.Date
  expiryDate    DateTime? @map("expiry_date") @db.Date
  fileId        String?   @map("file_id") @db.Uuid
  createdAt     DateTime? @map("created_at") @db.Timestamptz

  tenant     Tenant             @relation(fields: [tenantId], references: [id])
  enrollment TrainingEnrollment @relation(fields: [enrollmentId], references: [id])
  file       File?              @relation(fields: [fileId], references: [id])

  @@map("training_certificates")
}

model AssetCategory {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @map("id") @db.Uuid
  tenantId    String    @map("tenant_id") @db.Uuid
  code        String    @map("code") @db.VarChar(50)
  name        String    @map("name") @db.VarChar(150)
  description String?   @map("description") @db.Text
  createdAt   DateTime? @map("created_at") @db.Timestamptz
  updatedAt   DateTime? @map("updated_at") @db.Timestamptz

  tenant         Tenant  @relation(fields: [tenantId], references: [id])
  categoryAssets Asset[] @relation

  @@unique([tenantId, code])
  @@map("asset_categories")
}

model Asset {
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @map("id") @db.Uuid
  tenantId       String       @map("tenant_id") @db.Uuid
  categoryId     String       @map("category_id") @db.Uuid
  assetCode      String       @map("asset_code") @db.VarChar(100)
  assetName      String?      @map("asset_name") @db.VarChar(200)
  serialNumber   String?      @map("serial_number") @db.VarChar(200)
  manufacturer   String?      @map("manufacturer") @db.VarChar(150)
  model          String?      @map("model") @db.VarChar(150)
  purchaseDate   DateTime?    @map("purchase_date") @db.Date
  purchasePrice  Decimal?     @map("purchase_price") @db.Decimal(18, 2)
  warrantyExpiry DateTime?    @map("warranty_expiry") @db.Date
  currentStatus  AssetStatus? @map("current_status")
  metadata       Json?        @map("metadata") @db.JsonB
  createdAt      DateTime?    @map("created_at") @db.Timestamptz
  updatedAt      DateTime?    @map("updated_at") @db.Timestamptz

  tenant            Tenant             @relation(fields: [tenantId], references: [id])
  category          AssetCategory      @relation(fields: [categoryId], references: [id])
  assetAssignments  AssetAssignment[]  @relation
  assetMaintenances AssetMaintenance[] @relation
  assetDisposals    AssetDisposal[]    @relation

  @@unique([tenantId, assetCode])
  @@index([serialNumber])
  @@map("assets")
}

model AssetAssignment {
  id                    String            @id @default(dbgenerated("gen_random_uuid()")) @map("id") @db.Uuid
  tenantId              String            @map("tenant_id") @db.Uuid
  assetId               String            @map("asset_id") @db.Uuid
  employmentId          String            @map("employment_id") @db.Uuid
  assignedByPrincipalId String?           @map("assigned_by_principal_id") @db.Uuid
  assignedAt            DateTime          @map("assigned_at") @db.Timestamptz
  expectedReturnAt      DateTime?         @map("expected_return_at") @db.Timestamptz
  actualReturnAt        DateTime?         @map("actual_return_at") @db.Timestamptz
  assignmentStatus      AssignmentStatus? @map("assignment_status")
  note                  String?           @map("note") @db.Text
  createdAt             DateTime?         @map("created_at") @db.Timestamptz

  tenant                Tenant       @relation(fields: [tenantId], references: [id])
  asset                 Asset        @relation(fields: [assetId], references: [id])
  employment            Employment   @relation(fields: [employmentId], references: [id])
  assignedByPrincipal   Principal?   @relation(fields: [assignedByPrincipalId], references: [id])
  assignmentAssetReturn AssetReturn? @relation

  @@map("asset_assignments")
}

model AssetReturn {
  id                    String    @id @default(dbgenerated("gen_random_uuid()")) @map("id") @db.Uuid
  assignmentId          String    @unique @map("assignment_id") @db.Uuid
  returnedByPrincipalId String?   @map("returned_by_principal_id") @db.Uuid
  returnedAt            DateTime? @map("returned_at") @db.Timestamptz
  conditionNote         String?   @map("condition_note") @db.Text
  damageCost            Decimal?  @map("damage_cost") @db.Decimal(18, 2)
  createdAt             DateTime? @map("created_at") @db.Timestamptz

  assignment          AssetAssignment @relation(fields: [assignmentId], references: [id])
  returnedByPrincipal Principal?      @relation(fields: [returnedByPrincipalId], references: [id])

  @@map("asset_returns")
}

model AssetMaintenance {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @map("id") @db.Uuid
  tenantId        String    @map("tenant_id") @db.Uuid
  assetId         String    @map("asset_id") @db.Uuid
  maintenanceType String?   @map("maintenance_type") @db.VarChar(100)
  vendor          String?   @map("vendor") @db.VarChar(255)
  cost            Decimal?  @map("cost") @db.Decimal(18, 2)
  startedAt       DateTime? @map("started_at") @db.Timestamptz
  completedAt     DateTime? @map("completed_at") @db.Timestamptz
  note            String?   @map("note") @db.Text

  tenant Tenant @relation(fields: [tenantId], references: [id])
  asset  Asset  @relation(fields: [assetId], references: [id])

  @@map("asset_maintenances")
}

model AssetDisposal {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @map("id") @db.Uuid
  tenantId       String    @map("tenant_id") @db.Uuid
  assetId        String    @map("asset_id") @db.Uuid
  disposedAt     DateTime? @map("disposed_at") @db.Timestamptz
  disposalMethod String?   @map("disposal_method") @db.VarChar(100)
  disposalValue  Decimal?  @map("disposal_value") @db.Decimal(18, 2)
  reason         String?   @map("reason") @db.Text

  tenant Tenant @relation(fields: [tenantId], references: [id])
  asset  Asset  @relation(fields: [assetId], references: [id])

  @@map("asset_disposals")
}
