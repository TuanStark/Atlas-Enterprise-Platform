  description       String?   @map("description") @db.Text
  price             Decimal?  @map("price") @db.Decimal(18, 2)
  billingCycleMonth Int?      @map("billing_cycle_month")
  maxUsers          Int?      @map("max_users")
  maxStorageGb      Int?      @map("max_storage_gb")
  metadata          Json?     @map("metadata") @db.JsonB
  createdAt         DateTime? @map("created_at") @db.Timestamptz
  updatedAt         DateTime? @map("updated_at") @db.Timestamptz

  subscriptionPlanTenantSubscriptions TenantSubscription[] @relation

  @@map("subscription_plans")
}

