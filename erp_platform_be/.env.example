# --- Application Configuration ---
PORT=8080
NODE_ENV=development

# --- Database Configuration ---
# Format: postgresql://[user]:[password]@[host]:[port]/[database_name]?schema=public
# For local development connecting to docker-exposed Postgres:
DATABASE_URL=postgresql://postgres:postgres_password@localhost:5432/erp_db?schema=public

# --- JWT Configuration ---
JWT_SECRET=super_secret_key_change_me_in_production
ACCESS_TOKEN_EXPIRATION=3600s
REFRESH_TOKEN_EXPIRATION=7d

# --- Docker Compose (PostgreSQL) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres_password
POSTGRES_DB=erp_db
POSTGRES_PORT=5432

# --- Docker Compose (Redis) ---
REDIS_PORT=6379
REDIS_PASSWORD=redis_password

# --- Mail Configuration (SMTP) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_SECURE=false
MAIL_FROM="Atlas Platform <noreply@atlas.com>"

